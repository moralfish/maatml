# Python / IDE / OS
__pycache__/
*.pyc
.venv/
.env
.pytest_cache/
.mypy_cache/
.ruff_cache/
.DS_Store
.claude/
# Packaging / build metadata
*.egg-info/
.eggs/
build/
dist/
*.egg

# Per-model generated artifacts: keep folder structure, ignore content
models/*/output/**
!models/*/output/.gitkeep
examples/*/output/**
!examples/*/output/.gitkeep

# Generated dataset files (augmented from seeds at prepare time)
models/*/datasets/samples/augmented_*.jsonl
models/*/datasets/samples/*.parquet
examples/*/datasets/samples/augmented_*.jsonl
examples/*/datasets/samples/*.parquet

# Built archives
*.fm

.vscode/
/.idea/
/.codesight/

# Build / deploy artifacts (not committed)
/site/
/.wrangler/

# Ephemeral log the ml-smoke CI step tees; never tracked.
rerun.log
