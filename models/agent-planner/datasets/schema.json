{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Planner sample",
  "type": "object",
  "required": ["sample_id", "source", "request", "expected_intent", "agent_plan"],
  "properties": {
    "sample_id": { "type": "string" },
    "source": { "type": "string" },
    "request": { "type": "string" },
    "context": { "type": "string" },
    "expected_intent": { "type": "string" },
    "agent_plan": { "$ref": "#/$defs/AgentPlan" }
  },
  "$defs": {
    "AgentPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent_summary", "plan_steps", "tool_calls", "dsl_patch", "dsl", "confidence", "refusal_reason"],
      "properties": {
        "intent_summary": { "type": "string" },
        "plan_steps": {
          "type": "array",
          "items": { "$ref": "#/$defs/PlanStep" }
        },
        "tool_calls": {
          "type": "array",
          "items": { "$ref": "#/$defs/ToolCall" }
        },
        "dsl_patch": { "type": ["string", "null"] },
        "dsl": { "type": ["string", "null"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "refusal_reason": { "type": ["string", "null"] }
      }
    },
    "PlanStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "action", "depends_on"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "action": { "type": "string" },
        "depends_on": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "ToolCall": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "arguments"],
      "properties": {
        "name": { "type": "string" },
        "arguments": { "type": "object" }
      }
    }
  }
}
